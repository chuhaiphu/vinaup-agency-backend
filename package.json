{
  "name": "vinaup-agency-backend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:jenahair-api": "npm run start:dev --workspace=apps/jenahair-api",
    "build:jenahair-api": "npm run build --workspace=apps/jenahair-api",
    "start:jenahair-api": "npm run start:prod --workspace=apps/jenahair-api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=22"
  }
}
